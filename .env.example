# API — ชี้ไปที่ backend (account-stock-be). ว่าง = same-origin (proxy หรือ same host).
# Local: backend รันที่ :8080 → ใช้ http://localhost:8080 หรือตั้ง proxy ใน next.config
NEXT_PUBLIC_API_URL=

# Dev/test login — SuperAdmin (frontend-only; do not use in production)
# Copy to .env.local and set values. Used by User menu "Dev login".
NEXT_PUBLIC_TEST_USER=useradmin1234
NEXT_PUBLIC_TEST_PASS=pass@1

# Optional: default mock role when no backend (Staff | Viewer | Manager | Admin | SuperAdmin)
# NEXT_PUBLIC_MOCK_ROLE=Staff
