# ========== เรียกหลังบ้าน (account-stock-be) ==========
# Base URL ของ API (ไม่มี slash ท้าย). หน้าบ้านจะเรียก GET/POST ไปที่ ${NEXT_PUBLIC_API_URL}/api/...
#
# Local — backend รันที่ :8080:
NEXT_PUBLIC_API_URL=http://localhost:8080
#
# Production — ใส่ URL ที่ deploy backend แล้ว (เช่น Railway, App Runner):
# NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app
#
# ว่าง = same-origin (ถ้าหน้าบ้านกับหลังบ้านอยู่ host เดียวหรือใช้ proxy)
#
# CORS: เปิดหน้าบ้านที่ http://localhost:3000 หรือ http://127.0.0.1:3000 ให้ตรงกับ CORS_ORIGIN ของ backend (BE .env)

# Dev/test login — SuperAdmin (frontend-only; ห้ามใช้ใน production)
# ใช้กับเมนู User → "Dev login"
NEXT_PUBLIC_TEST_USER=useradmin1234
NEXT_PUBLIC_TEST_PASS=pass@1

# Optional: default mock role เมื่อไม่มี backend (Staff | Viewer | Manager | Admin | SuperAdmin)
# NEXT_PUBLIC_MOCK_ROLE=Staff

# Optional: calculator engine (ถ้าใช้ service แยก)
# NEXT_PUBLIC_CALC_ENGINE_URL=
# NEXT_PUBLIC_CALC_ENGINE_SECRET=
